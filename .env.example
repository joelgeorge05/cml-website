# Supabase – Frontend (Vite exposes only VITE_ prefixed vars to the browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service Role Key – used ONLY by migrate_to_supabase.js (server-side, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
